# Copy to .env (or set via systemd EnvironmentFile). Required vars have no default.

# ---- Discord ----
DISCORD_TOKEN=              # Bot token (Bot tab) — NOT the client secret
DISCORD_CLIENT_ID=          # Application / client ID
DISCORD_GUILD_ID=           # Your server (guild) ID

# ---- Clash of Clans ----
COC_TOKEN=                  # API token minted for THIS host's egress IP
COC_CLAN_TAG=               # e.g. #PVVY8L2L

# ---- Storage ----
COC_DB_PATH=data/coc.db     # SQLite path (use an absolute shared path in prod)

# ---- Channel routing (Discord channel IDs; unset => that feature is skipped) ----
CHANNEL_WAR_REMINDERS=
CHANNEL_WAR_LOG=
CHANNEL_CWL=
CHANNEL_CAPITAL=
CHANNEL_CLAN_FEED=
CHANNEL_DONATIONS=
CHANNEL_CLAN_HQ=          # Living dashboard: bot edits one pinned message here (needs Manage Messages to pin)
CHANNEL_VERIFY=

# ---- Clan-role -> Discord-role IDs (unset => that rank isn't assigned) ----
ROLE_LEADER=
ROLE_COLEADER=
ROLE_ELDER=
ROLE_MEMBER=

# ---- Tuning (optional; defaults shown) ----
POLL_WAR_SECONDS=300
POLL_MEMBERS_SECONDS=600
POLL_CAPITAL_SECONDS=3600
POLL_DONATIONS_SECONDS=3600  # How often to fold donation deltas; weekly post fires on ISO-week rollover
POLL_DASHBOARD_SECONDS=300   # How often the Clan HQ dashboard message re-renders
REMIND_HOURS_BEFORE=2       # Post the war attack reminder when this many hours remain
LOG_LEVEL=info
